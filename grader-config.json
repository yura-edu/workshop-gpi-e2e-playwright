{
  "schemaVersion": "1.0",
  "templateSlug": "gpi-e2e-playwright",
  "evaluationBlocks": [
    {
      "blockId": "auto",
      "evaluationType": "automated_pipeline",
      "metrics": [
        {
          "metricKey": "e2e_test_presence",
          "worker": "ConfigWorker",
          "weight": 25,
          "threshold": 1.0,
          "config": {
            "patterns": ["tests/e2e/*.spec.ts", "tests/e2e/*.spec.js", "e2e/*.spec.ts", "e2e/*.spec.js"]
          }
        },
        {
          "metricKey": "test_pass_rate",
          "worker": "TestWorker",
          "weight": 30,
          "threshold": 1.0,
          "config": {
            "command": "npx playwright test",
            "minPassRate": 1.0
          }
        },
        {
          "metricKey": "ci_pipeline_passes",
          "worker": "GitHubApiWorker",
          "weight": 25,
          "threshold": 1.0,
          "config": {
            "checkRunName": "e2e",
            "requireAllPassing": true
          }
        },
        {
          "metricKey": "test_pyramid_ratio",
          "worker": "TestWorker",
          "weight": 20,
          "threshold": 0.6,
          "config": {
            "e2ePattern": "tests/e2e/**/*.spec.{ts,js}",
            "allTestsPattern": "**/*.{spec,test}.{ts,js}",
            "minRatio": 0.6
          }
        }
      ]
    }
  ]
}
